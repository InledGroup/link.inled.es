---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Acortador de enlaces link.inled.es" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<!-- Main content area / Área de contenido principal -->
	<body>
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	/* Color System & Design Tokens / Sistema de Colores y Tokens de Diseño */
	:root {
		--bg-main: 210 40% 98%;
		--fg-main: 222 47% 11%;
		
		--card-bg: 0 0% 100%;
		--card-fg: 222 47% 11%;
		
		--primary: 222 47% 11%;
		--primary-fg: 210 40% 98%;
		
		--accent: 210 40% 96.1%;
		--accent-fg: 222 47% 11.2%;
		
		--muted: 210 40% 96.1%;
		--muted-fg: 215 16% 47%;
		
		--border: 214 32% 91%;
		--input-bg: 0 0% 100%;
		
		--destructive: 0 84% 60%;
		--destructive-fg: 210 40% 98%;
		
		--success: 142 71% 45%;
		--success-bg: 142 71% 95%;
		
		--radius-lg: 1rem;
		--radius-md: 0.75rem;
		--radius-sm: 0.5rem;
		
		--shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
		--shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
		--shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
	}

	/* Reset & Base Styles / Reset y Estilos Base */
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html, body {
		height: 100%;
		width: 100%;
		scroll-behavior: smooth;
	}

	html {
		font-family: 'Inter', system-ui, -apple-system, sans-serif;
		background-color: hsl(var(--bg-main));
		color: hsl(var(--fg-main));
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	body {
		display: flex;
		justify-content: center;
		padding: 1.5rem;
		min-height: 100vh;
	}

	@media (min-width: 768px) {
		body { padding: 3rem 2.5rem; }
	}

	main {
		width: 100%;
		max-width: 1200px;
		display: flex;
		flex-direction: column;
	}

	/* Typography / Tipografía */
	h1, h2, h3, h4 {
		font-weight: 800;
		letter-spacing: -0.025em;
		line-height: 1.2;
	}

	p {
		line-height: 1.6;
	}

	/* Interactive Components / Componentes Interactivos */
	.card {
		background-color: hsl(var(--card-bg));
		border: 1px solid hsl(var(--border));
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		border-radius: var(--radius-md);
		font-size: 0.875rem;
		font-weight: 600;
		height: 2.75rem;
		padding: 0 1.25rem;
		cursor: pointer;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		border: 1px solid transparent;
		user-select: none;
		text-decoration: none;
	}

	.btn-primary {
		background-color: hsl(var(--primary));
		color: hsl(var(--primary-fg));
		box-shadow: 0 4px 10px -2px hsla(var(--primary), 0.3);
	}
	.btn-primary:hover {
		transform: translateY(-1px);
		box-shadow: 0 6px 15px -3px hsla(var(--primary), 0.4);
		filter: brightness(1.1);
	}
	.btn-primary:active {
		transform: translateY(0);
	}
	.btn-primary:disabled {
		opacity: 0.7;
		cursor: not-allowed;
		transform: none;
	}

	.btn-outline {
		background-color: transparent;
		border: 1px solid hsl(var(--border));
		color: hsl(var(--fg-main));
	}
	.btn-outline:hover {
		background-color: hsl(var(--muted));
		border-color: hsl(var(--border));
	}

	.btn-destructive {
		background-color: transparent;
		border: 1px solid hsla(var(--destructive), 0.2);
		color: hsl(var(--destructive));
	}
	.btn-destructive:hover {
		background-color: hsl(var(--destructive));
		color: white;
		border-color: hsl(var(--destructive));
	}

	.btn-ghost {
		background-color: transparent;
		color: hsl(var(--muted-fg));
	}
	.btn-ghost:hover {
		background-color: hsl(var(--muted));
		color: hsl(var(--fg-main));
	}

	/* Form Elements / Elementos de Formulario */
	.form-control {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		width: 100%;
	}

	label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: hsl(var(--muted-fg));
		margin-left: 0.125rem;
	}

	input {
		width: 100%;
		height: 2.75rem;
		padding: 0 1rem;
		border-radius: var(--radius-md);
		border: 1px solid hsl(var(--border));
		background-color: hsl(var(--input-bg));
		font-size: 0.875rem;
		font-family: inherit;
		transition: all 0.2s;
		box-shadow: var(--shadow-sm);
	}

	input:focus {
		outline: none;
		border-color: hsl(var(--primary));
		box-shadow: 0 0 0 4px hsla(var(--primary), 0.1);
	}

	input::placeholder {
		color: hsl(var(--muted-fg) / 0.6);
	}

	/* Utilities / Utilidades */
	.text-muted { color: hsl(var(--muted-fg)); }
	.text-sm { font-size: 0.875rem; }
	.text-xs { font-size: 0.75rem; }
	.font-bold { font-weight: 700; }
	.hidden { display: none !important; }
	
	.flex { display: flex; }
	.flex-col { flex-direction: column; }
	.items-center { align-items: center; }
	.justify-between { justify-content: space-between; }
	.gap-2 { gap: 0.5rem; }
	.gap-4 { gap: 1rem; }
	.gap-6 { gap: 1.5rem; }
	.w-full { width: 100%; }

	/* Custom Scrollbar / Barra de Desplazamiento Personalizada */
	::-webkit-scrollbar { width: 8px; }
	::-webkit-scrollbar-track { background: transparent; }
	::-webkit-scrollbar-thumb { background: hsl(var(--border)); border-radius: 10px; }
	::-webkit-scrollbar-thumb:hover { background: hsl(var(--muted-fg) / 0.4); }
</style>
