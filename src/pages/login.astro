---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login - link.inled.es">
	<div class="login-center">
		<div class="login-container">
			<div class="logo">
				<img src="https://hosted.inled.es/inled-logo-full.png" alt="Inled Logo" height="48" />
			</div>
			<div class="card p-8">
				<div class="header mb-8 text-center">
					<h1 class="text-3xl font-bold tracking-tight mb-2">Acceso Restringido</h1>
					<p class="text-sm text-muted">Introduce la contraseña de administrador para gestionar tus enlaces.</p>
				</div>
				
				<form id="login-form">
					<div class="space-y-6">
						<div class="space-y-2">
							<label for="password" class="text-sm font-semibold ml-1">Contraseña</label>
							<input type="password" id="password" name="password" required autofocus placeholder="••••••••" />
						</div>
						<button type="submit" id="login-btn" class="btn btn-primary w-full text-base">Acceder al Panel</button>
					</div>
				</form>

				<div id="message" class="hidden mt-6 p-4 rounded-lg bg-destructive/10 text-destructive text-sm text-center font-medium border border-destructive/20"></div>
			</div>
			<p class="mt-8 text-center text-xs text-muted">
				&copy; 2026 Inled. Todos los derechos reservados.
			</p>
		</div>
	</div>
</Layout>

<style>
	.login-center {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: calc(100vh - 8rem);
	}
	.login-container {
		width: 100%;
		max-width: 440px;
	}
	.logo {
		display: flex;
		justify-content: center;
		margin-bottom: 2.5rem;
	}
	.p-8 { padding: 2rem; }
	.mb-2 { margin-bottom: 0.5rem; }
	.mb-8 { margin-bottom: 2rem; }
	.mt-6 { margin-top: 1.5rem; }
	.mt-8 { margin-top: 2rem; }
	.ml-1 { margin-left: 0.25rem; }
	.space-y-6 > * + * { margin-top: 1.5rem; }
	.space-y-2 > * + * { margin-top: 0.5rem; }
	.w-full { width: 100%; }
	.text-3xl { font-size: 1.875rem; line-height: 2.25rem; }
	.text-base { font-size: 1rem; }
	.font-bold { font-weight: 700; }
	.font-semibold { font-weight: 600; }
	.font-medium { font-weight: 500; }
	.text-sm { font-size: 0.875rem; }
	.text-xs { font-size: 0.75rem; }
	.text-muted { color: hsl(var(--muted-foreground)); }
	.text-destructive { color: hsl(var(--destructive)); }
	.bg-destructive\/10 { background-color: hsl(var(--destructive) / 0.1); }
	.border-destructive\/20 { border-color: hsl(var(--destructive) / 0.2); }
	.text-center { text-align: center; }
	.hidden { display: none; }
	.tracking-tight { letter-spacing: -0.025em; }
</style>

<script>
	const form = document.getElementById('login-form') as HTMLFormElement;
	const message = document.getElementById('message') as HTMLDivElement;
	const btn = document.getElementById('login-btn') as HTMLButtonElement;

	form.addEventListener('submit', async (e) => {
		e.preventDefault();
		message.classList.add('hidden');
		btn.disabled = true;
		btn.textContent = 'Verificando...';

		const password = (document.getElementById('password') as HTMLInputElement).value;

		try {
			const res = await fetch('/api/login', {
				method: 'POST',
				body: JSON.stringify({ password }),
				headers: { 'Content-Type': 'application/json' }
			});

			if (res.ok) {
				window.location.href = '/';
			} else {
				message.classList.remove('hidden');
				message.textContent = 'Contraseña incorrecta. Inténtalo de nuevo.';
			}
		} catch (error) {
			message.classList.remove('hidden');
			message.textContent = 'Error de conexión con el servidor.';
		} finally {
			btn.disabled = false;
			btn.textContent = 'Acceder al Panel';
		}
	});
</script>
