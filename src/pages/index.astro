---
import Layout from '../layouts/Layout.astro';
---

<Layout title="link.inled.es - Acortador">
	<div class="container">
		<div class="header">
			<h1>link.inled.es</h1>
			<button id="logout-btn" class="secondary">Cerrar Sesión</button>
		</div>

		<div class="card">
			<h2>Acortar Enlace</h2>
			<p class="subtitle">Personaliza tu link corto</p>
			
			<form id="shorten-form">
				<div class="field">
					<label for="url">URL original</label>
					<input type="url" id="url" name="url" required placeholder="https://ejemplo.com/mi-pagina-larga" />
				</div>

				<div class="field">
					<label for="slug">Slug (parte final)</label>
					<div class="slug-input">
						<span>link.inled.es/</span>
						<input type="text" id="slug" name="slug" required placeholder="mi-link" />
					</div>
				</div>

				<button type="submit" id="submit-btn">Crear enlace acortado</button>
			</form>

			<div id="message" class="hidden"></div>
		</div>

		<div class="card management">
			<div class="manage-header">
				<h2>Gestión de Enlaces</h2>
				<button id="refresh-btn" class="secondary">Refrescar Lista</button>
			</div>
			
			<div class="manage-actions">
				<button id="export-btn" class="secondary">Exportar JSON</button>
				<label for="import-file" class="button secondary">Importar JSON</label>
				<input type="file" id="import-file" accept=".json" style="display: none;" />
			</div>

			<div id="links-list-container">
				<table id="links-table" class="hidden">
					<thead>
						<tr>
							<th>Slug</th>
							<th>URL Destino</th>
							<th>Acción</th>
						</tr>
					</thead>
					<tbody id="links-body"></tbody>
				</table>
				<p class="empty-msg">Cargando enlaces...</p>
			</div>
		</div>
	</div>
</Layout>

<style>
	.container {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		width: 100%;
	}
	.header {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.card {
		background: var(--white);
		padding: 2rem;
		border-radius: 1rem;
		box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
	}
	.manage-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.5rem;
	}
	.manage-actions {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}
	h1 { font-size: 1.8rem; }
	h2 { font-size: 1.3rem; margin-bottom: 0.5rem; }
	.subtitle {
		color: #64748b;
		font-size: 0.9rem;
		margin-bottom: 1.5rem;
	}
	form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.field {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	label {
		font-weight: 600;
		font-size: 0.875rem;
	}
	input {
		padding: 0.75rem;
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		font-size: 1rem;
	}
	.slug-input {
		display: flex;
		align-items: center;
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		padding-left: 0.75rem;
		background: #f1f5f9;
	}
	.slug-input span {
		color: #64748b;
		font-size: 0.9rem;
	}
	.slug-input input {
		border: none;
		background: transparent;
		width: 100%;
	}
	button, .button {
		background: var(--primary);
		color: white;
		border: none;
		padding: 1rem;
		border-radius: 0.5rem;
		font-weight: 700;
		cursor: pointer;
		text-align: center;
	}
	button.secondary {
		background: #64748b;
		padding: 0.5rem 1rem;
		font-size: 0.8rem;
	}
	button.delete-btn {
		background: var(--error);
		padding: 0.4rem 0.8rem;
		font-size: 0.75rem;
	}
	#message {
		margin-top: 1.5rem;
		padding: 1rem;
		border-radius: 0.5rem;
		font-size: 0.9rem;
		text-align: center;
	}
	#message.error { background: #fee2e2; color: #991b1b; }
	#message.success { background: #d1fae5; color: #065f46; }
	.hidden { display: none; }
	table {
		width: 100%;
		border-collapse: collapse;
		margin-top: 1rem;
		font-size: 0.85rem;
	}
	th, td {
		text-align: left;
		padding: 0.75rem;
		border-bottom: 1px solid var(--border);
	}
	.url-cell {
		max-width: 150px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.empty-msg {
		color: #64748b;
		text-align: center;
		padding: 1rem;
	}
</style>

<script>
	const form = document.getElementById('shorten-form') as HTMLFormElement;
	const message = document.getElementById('message') as HTMLDivElement;
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
	const refreshBtn = document.getElementById('refresh-btn') as HTMLButtonElement;
	const logoutBtn = document.getElementById('logout-btn') as HTMLButtonElement;
	const exportBtn = document.getElementById('export-btn') as HTMLButtonElement;
	const importFile = document.getElementById('import-file') as HTMLInputElement;
	const linksTable = document.getElementById('links-table') as HTMLTableElement;
	const linksBody = document.getElementById('links-body') as HTMLTableSectionElement;
	const emptyMsg = document.querySelector('.empty-msg') as HTMLParagraphElement;

	// Cargar al inicio
	document.addEventListener('DOMContentLoaded', loadLinks);

	async function logout() {
		// Para cerrar sesión simplemente borramos la cookie (esto se puede hacer por API o por JS si no es HttpOnly)
		// Como es HttpOnly, lo haremos por una API simple o redirigiendo a un logout
		document.cookie = "auth_session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
		window.location.href = '/login';
	}
	
	logoutBtn.addEventListener('click', async () => {
		// Llamamos a una api de logout para limpiar la cookie httponly
		await fetch('/api/logout', { method: 'POST' });
		window.location.href = '/login';
	});

	form.addEventListener('submit', async (e) => {
		e.preventDefault();
		message.className = 'hidden';
		submitBtn.disabled = true;

		const formData = new FormData(form);
		const data = Object.fromEntries(formData);

		try {
			const response = await fetch('/api/create', {
				method: 'POST',
				body: JSON.stringify(data),
				headers: { 'Content-Type': 'application/json' }
			});

			const result = await response.json();

			if (response.ok) {
				message.className = 'success';
				message.innerHTML = `¡Creado! <a href="/${data.slug}" target="_blank">link.inled.es/${data.slug}</a>`;
				form.reset();
				loadLinks();
			} else {
				message.className = 'error';
				message.textContent = result.error;
			}
		} catch (error) {
			message.className = 'error';
			message.textContent = 'Error de conexión';
		} finally {
			submitBtn.disabled = false;
		}
	});

	async function loadLinks() {
		try {
			const response = await fetch('/api/manage', {
				method: 'POST',
				body: JSON.stringify({ action: 'list' }),
				headers: { 'Content-Type': 'application/json' }
			});
			const result = await response.json();
			
			if (response.ok) {
				renderLinks(result.links);
			} else if (response.status === 401) {
				window.location.href = '/login';
			}
		} catch (e) {
			console.error('Error al cargar enlaces');
		}
	}

	function renderLinks(links: any[]) {
		linksBody.innerHTML = '';
		if (links.length === 0) {
			linksTable.classList.add('hidden');
			emptyMsg.classList.remove('hidden');
			emptyMsg.textContent = 'No hay enlaces.';
			return;
		}

		linksTable.classList.remove('hidden');
		emptyMsg.classList.add('hidden');

		links.forEach(link => {
			const tr = document.createElement('tr');
			tr.innerHTML = `
				<td><strong>/${link.slug}</strong></td>
				<td class="url-cell">${link.url}</td>
				<td><button class="delete-btn" data-id="${link.id}">Borrar</button></td>
			`;
			linksBody.appendChild(tr);
		});

		document.querySelectorAll('.delete-btn').forEach(btn => {
			btn.addEventListener('click', async (e) => {
				if (!confirm('¿Borrar?')) return;
				const id = (e.target as HTMLButtonElement).dataset.id;
				await fetch('/api/manage', {
					method: 'POST',
					body: JSON.stringify({ action: 'delete', data: { id } }),
					headers: { 'Content-Type': 'application/json' }
				});
				loadLinks();
			});
		});
	}

	refreshBtn.addEventListener('click', loadLinks);

	exportBtn.addEventListener('click', async () => {
		const response = await fetch('/api/manage', {
			method: 'POST',
			body: JSON.stringify({ action: 'export' }),
			headers: { 'Content-Type': 'application/json' }
		});
		const result = await response.json();
		if (response.ok) {
			const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(result.links, null, 2));
			const downloadAnchorNode = document.createElement('a');
			downloadAnchorNode.setAttribute("href",     dataStr);
			downloadAnchorNode.setAttribute("download", "links_export.json");
			downloadAnchorNode.click();
			downloadAnchorNode.remove();
		}
	});

	importFile.addEventListener('change', async (e) => {
		const file = (e.target as HTMLInputElement).files?.[0];
		if (!file) return;
		const reader = new FileReader();
		reader.onload = async (event) => {
			try {
				const data = JSON.parse(event.target?.result as string);
				const response = await fetch('/api/manage', {
					method: 'POST',
					body: JSON.stringify({ action: 'import', data }),
					headers: { 'Content-Type': 'application/json' }
				});
				if (response.ok) {
					alert('Importado');
					loadLinks();
				}
			} catch (err) {
				alert('JSON inválido');
			}
		};
		reader.readAsText(file);
	});
</script>
